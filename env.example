# .env
# -----
# Copy this file to .env and fill in your values.
# Never commit .env to GitHub — it contains secrets.
# .env is already in .gitignore.

# Get your free API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Only needed if running backend outside Docker
# Docker Compose sets this automatically via docker-compose.yml
# DATABASE_URL=postgresql://retention_user:retention_pass@localhost:5432/retention_db
